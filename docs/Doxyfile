# Doxygen configuration for the VKNN API docs. Run: ./build.sh --docs  (or ./scripts/gen_docs.sh)
PROJECT_NAME           = "VKNN"
PROJECT_BRIEF          = "Vulkan Neural Network — on-device inference engine (CNNs, transformers, 3D Gaussian Splatting)"
OUTPUT_DIRECTORY       = docs/api
INPUT                  = include/vknn src
FILE_PATTERNS          = *.h *.hpp *.cpp *.glsl *.comp
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
JAVADOC_AUTOBRIEF      = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
SOURCE_BROWSER         = YES
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                 += README.md docs/ARCHITECTURE.md docs/ADDING_AN_OPERATOR.md \
                         docs/ADDING_A_BACKEND.md docs/CONFIG.md docs/LIMITATIONS.md

# Stock Doxygen theme. The hand-built site (docs/site, via ./build.sh --docs) is the primary docs;
# this C++ API reference is secondary and linked from it.
GENERATE_TREEVIEW      = YES
HTML_COLORSTYLE        = LIGHT
