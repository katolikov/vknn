# Doxygen configuration for vxrt API docs. Run: ./scripts/gen_docs.sh
PROJECT_NAME           = "vxrt"
PROJECT_BRIEF          = "Vulkan-eXynos RunTime — on-device CNN inference engine"
OUTPUT_DIRECTORY       = docs/api
INPUT                  = include/vx src
FILE_PATTERNS          = *.h *.hpp *.cpp *.glsl *.comp
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
EXTRACT_PRIVATE        = NO
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
JAVADOC_AUTOBRIEF      = YES
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
SOURCE_BROWSER         = YES
GENERATE_TREEVIEW      = YES
USE_MDFILE_AS_MAINPAGE = README.md
INPUT                 += README.md docs/ARCHITECTURE.md docs/ADDING_AN_OPERATOR.md \
                         docs/ADDING_A_BACKEND.md docs/CONFIG.md docs/LIMITATIONS.md
