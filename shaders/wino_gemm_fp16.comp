#version 450
// Winograd F(2x2,3x3) transform-domain matmul, as a TILED batched GEMM (the structure MNN's
// OpenCL backend uses via CLBlast XgemmBatched). This is the piece that makes Winograd actually
// win: the naive 1-thread-per-output matmul is memory-bound on the global V/M traffic, but a
// register-blocked, LDS-staged GEMM amortizes those loads across a workgroup tile.
//
// For each of the 16 transform positions p:  M[p][tile][oc] = sum_ic V[p][ic][tile] * U[p][oc][ic]
//   A = V[p]  : [K=Cinb][M=nT]      vec4 over 4 input channels   (from wino_input)
//   B = U[p]  : [N=Cout][K=Cinb]    vec4 over 4 input channels   (host weight transform)
//   C = M[p]  : [M=nT][N=Coutb]     vec4 over 4 output channels  (consumed by wino_out)
//
// One workgroup (64 threads = 8x8) computes a TILE_M x (TILE_NB output-channel-blocks) output tile
// for one position. Each thread owns RM tiles x 1 ocb (4 vec4 accumulators). A/B K-chunks are
// staged in shared memory so every thread reuses them.
#extension GL_EXT_shader_16bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
#include "common.glsl"

#define MDIM 8      // threads in M
#define NDIM 8      // threads in N   (MDIM*NDIM = 64)
#define RM 4        // tiles per thread (M micro-tile); 8 regresses (register pressure)
#define KWG 16      // input channel-blocks (K) staged per chunk
#define TILE_M (MDIM * RM)   // output tiles (M) per workgroup
#define TILE_NB NDIM         // output channel-blocks (N) per workgroup

layout(local_size_x = 64) in;
layout(std430, binding = 0) readonly buffer V { f16vec4 vbuf[]; };
layout(std430, binding = 1) readonly buffer U { f16vec4 ubuf[]; };
layout(std430, binding = 2) writeonly buffer M { f16vec4 mbuf[]; };
layout(push_constant) uniform PC { int Cin, Cout, nT; } pc;

shared f16vec4 sA[KWG][TILE_M];      // V tile  [k][m]
shared f16vec4 sB[KWG][TILE_NB * 4]; // U tile  [k][oc]

void main() {
  int Cinb = (pc.Cin + 3) / 4;
  int Coutb = (pc.Cout + 3) / 4;
  int p = int(gl_WorkGroupID.z);
  int m0 = int(gl_WorkGroupID.x) * TILE_M;       // first tile
  int nb0 = int(gl_WorkGroupID.y) * TILE_NB;     // first ocb

  uint lid = gl_LocalInvocationID.x;
  int tIdM = int(lid) % MDIM;   // 0..7
  int tIdN = int(lid) / MDIM;   // 0..7

  int vBaseP = p * Cinb * pc.nT;        // vbuf[(p*Cinb + k)*nT + m]
  int uBaseP = p * pc.Cout * Cinb;      // ubuf[(p*Cout + oc)*Cinb + k]

  vec4 acc[RM];
  for (int r = 0; r < RM; ++r) acc[r] = vec4(0.0);

  for (int k0 = 0; k0 < Cinb; k0 += KWG) {
    // ---- cooperative load of A (V) [KWG][TILE_M] and B (U) [KWG][TILE_NB*4] ----
    for (int i = int(lid); i < KWG * TILE_M; i += 64) {
      int kk = i / TILE_M, mm = i % TILE_M;
      int k = k0 + kk, m = m0 + mm;
      sA[kk][mm] = (k < Cinb && m < pc.nT) ? vbuf[vBaseP + k * pc.nT + m] : f16vec4(0.0);
    }
    for (int i = int(lid); i < KWG * TILE_NB * 4; i += 64) {
      int oo = i / KWG, kk = i % KWG;           // oo: 0..TILE_NB*4-1 (output channel)
      int k = k0 + kk, oc = nb0 * 4 + oo;
      sB[kk][oo] = (k < Cinb && oc < pc.Cout) ? ubuf[uBaseP + oc * Cinb + k] : f16vec4(0.0);
    }
    barrier();

    // ---- register-blocked multiply: RM tiles x (1 ocb = 4 oc) per thread ----
    int kmax = min(KWG, Cinb - k0);
    int ocb = tIdN;            // this thread's output channel-block within the tile
    for (int kk = 0; kk < kmax; ++kk) {
      vec4 b0 = vec4(sB[kk][ocb * 4 + 0]);
      vec4 b1 = vec4(sB[kk][ocb * 4 + 1]);
      vec4 b2 = vec4(sB[kk][ocb * 4 + 2]);
      vec4 b3 = vec4(sB[kk][ocb * 4 + 3]);
      for (int r = 0; r < RM; ++r) {
        vec4 a = vec4(sA[kk][tIdM + r * MDIM]);
        acc[r] += vec4(dot(a, b0), dot(a, b1), dot(a, b2), dot(a, b3));
      }
    }
    barrier();
  }

  // ---- store M[p][tile][ocb] ----  mbuf[(p*nT + tile)*Coutb + ocb]
  int ocb = nb0 + tIdN;
  if (ocb < Coutb) {
    int cBaseP = p * pc.nT * Coutb;
    int m = m0 + tIdM;
    for (int r = 0; r < RM; ++r)
      if (m + r * MDIM < pc.nT) mbuf[cBaseP + (m + r * MDIM) * Coutb + ocb] = f16vec4(acc[r]);
  }
}
