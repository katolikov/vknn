#version 450
// Generic uint32 buffer fill (used to clear the sort key buffer to 0xFFFFFFFF and the atomic counter
// to 0 before the GPU binning pass).
layout(local_size_x = 256) in;
layout(std430, binding = 0) buffer Buf { uint b[]; };
layout(push_constant) uniform PC { uint count, value; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i < pc.count) b[i] = pc.value;
}
