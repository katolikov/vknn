#version 450
// Elementwise unary (Sigmoid/Tanh/HardSwish/...). Layout-agnostic: operates on the packed buffer.
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) readonly  buffer S { float s[]; };
layout(std430, binding = 1) writeonly buffer D { float d[]; };
layout(push_constant) uniform PC { uint count; int op; float a, b; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  d[i] = vx_unary(s[i], pc.op, pc.a, pc.b);
}
