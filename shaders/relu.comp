#version 450
#include "precision.glsl"
// Standalone ReLU over a packed fp16 buffer.
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) readonly buffer Src { STORE a[]; };
layout(std430, binding = 1) writeonly buffer Dst { STORE c[]; };
layout(push_constant) uniform PC { uint count; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  c[i] = max(a[i], STORE(0.0));
}
