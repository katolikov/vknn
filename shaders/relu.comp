#version 450
// Standalone ReLU over a packed buffer (elementwise, layout-agnostic). fp32.
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) readonly buffer Src { float a[]; };
layout(std430, binding = 1) writeonly buffer Dst { float c[]; };
layout(push_constant) uniform PC { uint count; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  c[i] = max(a[i], 0.0);
}
