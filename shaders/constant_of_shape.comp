#version 450
// ConstantOfShape fill: write `value` into every output element. One thread per element.
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) writeonly buffer D { float d[]; };
layout(push_constant) uniform PC { uint count; float value; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  d[i] = pc.value;
}
