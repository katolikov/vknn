#version 450
// EyeLike fill: out[i,j] = (j - i == k) ? 1 : 0, row-major over a rows x cols matrix.
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) writeonly buffer D { float d[]; };
layout(push_constant) uniform PC { uint count; int rows, cols, k; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  int r = int(i) / pc.cols, c = int(i) % pc.cols;
  d[i] = (c - r == pc.k) ? 1.0 : 0.0;
}
