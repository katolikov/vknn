#version 450
#include "precision.glsl"
// EyeLike fill, fp16/fp32 storage (see eyelike.comp).
#include "common.glsl"
layout(local_size_x = 256) in;
layout(std430, binding = 0) writeonly buffer D { STORE d[]; };
layout(push_constant) uniform PC { uint count; int rows, cols, k; } pc;
void main() {
  uint i = gl_GlobalInvocationID.x;
  if (i >= pc.count) return;
  int r = int(i) / pc.cols, c = int(i) % pc.cols;
  d[i] = STORE((c - r == pc.k) ? 1.0 : 0.0);
}
